# 1. .env 파일에서 연료(키) 추출
$env_file = Get-Content .env | ConvertFrom-StringData
$api_key = $env_file.GOOGLE_TRANSLATE_API_KEY

# 연료가 비었는지 철저히 검사 (막내의 우려 불식!)
if (-not $api_key) {
    Write-Host "🚨 에러: .env 파일에서 키를 찾을 수 없습니다! 연료 주입 실패!" -ForegroundColor Red
    exit
}

Write-Host "🚀 연료 주입 완료(Key 확인됨)! 함선 배포 작전을 시작합니다..." -ForegroundColor Cyan

# 2. 낡은 찌꺼기 청소
flutter clean

# 3. 연료(API 키)를 엔진에 직접 꽂아서 빌드 (막내가 했던 그 방식 자동화!)
flutter build web --dart-define=GOOGLE_TRANSLATE_API_KEY=$api_key

# 4. 파이어베이스로 쏘아 올리기
firebase deploy --only hosting

Write-Host "✅ 배포가 완벽하게 종료되었습니다! 이제 번역이 잘 될 겁니다." -ForegroundColor Green